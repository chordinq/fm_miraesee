      }
    },
    {
      "m_Id": 48422304018432,
      "m_Localized": "اجمع المكافآت",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 52887002214400,
      "m_Localized": "التجمعات",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623317729280,
      "m_Localized": "القوة الموصى بها:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312192,
      "m_Localized": "إجمالي القوة:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312193,
      "m_Localized": "جارٍ التجمع... {0}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312194,
      "m_Localized": "{0} أكمل <color=#{2}>مهمة من المستوى {1}</color>",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312195,
      "m_Localized": "مهمة {0}!",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 10232987525308416,
      "m_Localized": "الدعم:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 14155878936276992,
      "m_Localized": "اجمع الكل",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6251320826327040,
      "m_Localized": "تحديث",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6882146555457536,
      "m_Localized": "جارٍ القتال...",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 25460050683224064,
      "m_Localized": "وقت التجمع",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695739834368,
      "m_Localized": "عواء العصر الأول",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417280,
      "m_Localized": "زحفت قبيلة منسية من البرية وهي تهاجم القوافل بالحجر والعظم. إن لم يُردّوا على أعقابهم، فستضم أراضي صيدهم عشيرتك قريبًا.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417281,
      "m_Localized": "العصر الحجري الثاني",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417282,
      "m_Localized": "ما كان يومًا مجرد جماعة بسيطة قد أصبح شيئًا أسوأ. إن لم يتحرك عشيرتك، فسوف يحكمون هذه الأراضي قريبًا.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417283,
      "m_Localized": "السامورائيان التوأم",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417284,
      "m_Localized": "يجوب سيافان بارعان أراضيك، يحصدون كل من يتحداهم. اهزم التوأمين قبل أن تغرق أسطورتهما عشيرتك في الخوف.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417285,
      "m_Localized": "فيلق الخوذة",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417286,
      "m_Localized": "يختبئ هؤلاء المقاتلون خلف الحديد والأسلحة الثقيلة، معتقدين أنهم منيعون. أرهم أن الفولاذ نفسه ينحني أمام عشيرتك.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417287,
      "m_Localized": "الأشرعة السوداء",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417288,
      "m_Localized": "رست سفن بلا أعلام قرب أراضيك. يخطط القراصنة لنهب كل ما هو غير مثبت.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417289,
      "m_Localized": "الفرسان الثلاثة",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417290,
      "m_Localized": "يسعى هؤلاء المعلمون لإثبات أنهم وحدهم يستحقون الاحترام والحكم. أرهم أن عشيرتك لا تنحني لأي شفرة.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417291,
      "m_Localized": "هجوم البلطجية",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417292,
      "m_Localized": "جاءت عصابة من البلطجية لجمع \"ضريبة\" من دخل عشيرتك الذي كسبته بشق الأنفس. لقد رفضت الدفع — والآن هم على بواباتك. اثبت في موقعك وأرهم أن عشيرتك لا تنحني للتهديدات.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417293,
      "m_Localized": "القانون يطرق الباب",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417294,
      "m_Localized": "رفضت شراكة الديكتاتور، مفضلًا الحرية على الأغلال. والآن تزحف وحداته المدرعة لتجعل من شعبك عبرة.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417295,
      "m_Localized": "الطليعة السامة",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 78356377112666112,
      "m_Localized": "دخلت وحدة مقنعة مسلحة بتقنية محرمة أراضيك، تاركةً وراءها هواءً محترقًا. أوقف زحفهم قبل أن يتسببوا في مزيد من الضرر.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417297,
      "m_Localized": "شفرات النجوم",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417298,
      "m_Localized": "هبطت فرقة من المحاربين بسيوف متوهجة، معلنين أن عشيرتك غير مؤهلة لحكم هذه الأراضي. اطردهم قبل أن يقرروا مصيرك إلى الأبد.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417299,
      "m_Localized": "غزو الفضائيين",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417300,
      "m_Localized": "بدأت كائنات من نجم آخر تحصد شعبك كالماشية. قاوم قبل أن يصبح وطنك مستعمرتهم.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417301,
      "m_Localized": "الشفرة العملاقة",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417302,
      "m_Localized": "يقاتل المحارب بشفرة أكبر من أي منزل. إن لم تستطع عشيرتك إيقافه، فلن يوقفه شيء آخر.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417303,
      "m_Localized": "اختراق رقمي",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417304,
      "m_Localized": "أطلق شق في عالم البيانات محاربين غريبين من الضوء والأرقام. أغلق الشق قبل أن يعيدوا كتابة أراضيك.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417305,
      "m_Localized": "التقنية ليست كافية",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417306,
      "m_Localized": "تسلح المقاتلون العاديون بشفرات تقنية متوهجة، معتقدين أنها تجعلهم منيعين. أثبت أن القوة الحقيقية لا تزال مهمة.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417307,
      "m_Localized": "متمردو الكم",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417308,
      "m_Localized": "ظهرت مجموعة من المحاربين البارزين، مسلحين بأسلحة كمية غير مستقرة. قوتهم متوحشة وخطيرة، وعلى عشيرتك إيقافهم قبل أن ينتشر الضرر.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417309,
      "m_Localized": "نظام العرش",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417310,
      "m_Localized": "أرسل الحاكم حراسه النخبة لإخضاع عشيرتك للتاج. أظهر أن عشيرتك لا تجيب لأي عرش.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417311,
      "m_Localized": "الساحران",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417312,
      "m_Localized": "يدعي السحرة أنهم جاؤوا لـ\"إعادة تشكيل\" أراضيك بما يلائمهم. على عشيرتك أن تردّ الفولاذ بالشجاعة وتكسر تعويذاتهم.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417313,
      "m_Localized": "النزول من الأعلى",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417314,
      "m_Localized": "نزل جيش من الملائكة، مدّعين أن عشيرتك أصبحت متكبرة جدًا. أثبت جدارتك، أو امحُ باسم الطهارة.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417315,
      "m_Localized": "سحرة الليل",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417316,
      "m_Localized": "أينما يسير هؤلاء السحرة، تفشل المحاصيل ويختفي الناس. اطردهم قبل أن يصبح وطنك مكانًا ميتًا آخر.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417317,
      "m_Localized": "من العالم السفلي",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417318,
      "m_Localized": "خرج المحاربون من الأعماق حيث لا ينتمي الأحياء. إن لم توقفهم عشيرتك، فستصبح السطح مملكتهم الجديدة.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 88072866833096704,
      "m_Localized": "مستويات المهمة {0}-{1}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 90987145798344704,
      "m_Localized": "أنت بالفعل في مهمة أخرى!",
      "m_Metadata": {
        "m_Items": []
      }
    }
  ],
