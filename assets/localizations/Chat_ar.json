      }
    },
    {
      "m_Id": 404956870860800,
      "m_Localized": "تم الإبلاغ عن المستخدم",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 407420491784192,
      "m_Localized": "إلغاء كتم الصوت",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 460145283817472,
      "m_Localized": "تمت المشاركة في الدردشة",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 460375794376704,
      "m_Localized": "شارك",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 14149557431558144,
      "m_Localized": "بريد مزعج",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290084843520,
      "m_Localized": "لا تتحرش بالآخرين أو تهنهم أو تهددهم.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009344,
      "m_Localized": "لا تستخدم خطاب الكراهية أو الإهانات أو اللغة التمييزية.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009345,
      "m_Localized": "لا تناقش المخدرات أو الدين أو السياسة أو المواضيع الجنسية.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009346,
      "m_Localized": "لا ترسل رسائل مزعجة أو تغرق الدردشة.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009347,
      "m_Localized": "لا تنتحل شخصية لاعبين آخرين أو المشرفين أو الموظفين.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009348,
      "m_Localized": "لا تشارك معلومات خاصة أو شخصية.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009349,
      "m_Localized": "لا تسئ استخدام نظام الإبلاغ.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009350,
      "m_Localized": "اعثر على مزيد من المعلومات في",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009351,
      "m_Localized": "قواعد الدردشة",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 35993381137014784,
      "m_Localized": "تم كتم صوتك لمدة",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 71558567759437824,
      "m_Localized": "وضع الدردشة الداكن",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 73683019230076928,
      "m_Localized": "خطاب كراهية",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 73683200906354688,
      "m_Localized": "تهديدات/عنف",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 73683325225525248,
      "m_Localized": "أنشطة غير قانونية",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 73683413213634560,
      "m_Localized": "احتيال",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 73683591861624832,
      "m_Localized": "انتحال شخصية",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 73683883986509824,
      "m_Localized": "انتهاك الملكية الفكرية",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 73684015041732608,
      "m_Localized": "انتهاك الخصوصية/كشف الهوية",
