      "m_Localized": "일시적으로 금지되었습니다!",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 42396247397490688,
      "m_Localized": "영구적으로 금지되었습니다!",
      "m_Metadata": {
        "m_Items": []
