    {
      "m_Id": 42205092823162881,
      "m_Localized": "업데이트 필요!",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 42205092823162882,
      "m_Localized": "게임을 계속하려면 업데이트하세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 42205092823162883,
      "m_Localized": "업데이트가 보이지 않나요?\n앱 스토어를 다시 시작하고 다시 확인해보세요.",
