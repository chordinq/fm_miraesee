      }
    },
    {
      "m_Id": 10232987525308416,
      "m_Localized": "Wsparcie:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 14155878936276992,
      "m_Localized": "Odbierz wszystko",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6251320826327040,
      "m_Localized": "Odśwież",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6882146555457536,
      "m_Localized": "Walka trwa...",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 25460050683224064,
      "m_Localized": "Czas zwołania",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695739834368,
      "m_Localized": "Wycie Pierwszej Ery",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417280,
      "m_Localized": "Zapomniane plemię wypełzło z dziczy i napada na karawany kamieniem i kością. Jeśli nie zostaną odparci, ich tereny łowieckie wkrótce obejmą twój klan.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417281,
      "m_Localized": "Druga Epoka Kamienia",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417282,
      "m_Localized": "To, co kiedyś było prostą grupą, stało się czymś gorszym. Jeśli twój klan nie zacznie działać, wkrótce będą rządzić tymi ziemiami.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417283,
      "m_Localized": "Bliźniaczy Samurajowie",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417284,
      "m_Localized": "Dwóch mistrzów miecza wędruje po twoich ziemiach, ścinając każdego, kto ich wyzwie. Pokonaj bliźniaków, zanim ich legenda utopi twój klan w strachu.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417285,
      "m_Localized": "Legion Hełmów",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417286,
      "m_Localized": "Ci wojownicy chowają się za żelazem i ciężką bronią, wierząc, że są niezniszczalni. Pokaż im, że nawet stal ugina się przed twoim klanem.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417287,
      "m_Localized": "Czarne Żagle",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417288,
      "m_Localized": "Statki bez flag zarzuciły kotwicę w pobliżu twoich ziem. Piraci planują złupić wszystko, co nie jest przybite.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417289,
      "m_Localized": "Trzej Muszkieterowie",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417290,
      "m_Localized": "Ci mistrzowie chcą udowodnić, że tylko oni zasługują na szacunek i władzę. Pokaż im, że twój klan nie kłania się żadnej klindze.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417291,
      "m_Localized": "Atak Zbirów",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417292,
      "m_Localized": "Banda zbirów przyszła pobrać „podatek\" z ciężko zarobionych dochodów twojego klanu. Odmówiłeś zapłaty – a teraz są pod twoimi bramami. Stań twardo i pokaż im, że twój klan nie ugnie się przed groźbami.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417293,
      "m_Localized": "Prawo Puka do Drzwi",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417294,
      "m_Localized": "Odrzuciłeś partnerstwo z dyktatorem, wybierając wolność zamiast kajdan. Teraz jego oddziały pancerne maszerują, by zrobić z twoich ludzi przykład.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417295,
      "m_Localized": "Toksyczna Awangarda",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 78356377112666112,
      "m_Localized": "Zamaskowana jednostka uzbrojona w zakazaną technologię weszła na twoje terytorium, zostawiając za sobą spalone powietrze. Zatrzymaj ich pochód, zanim wyrządzą więcej szkód.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417297,
      "m_Localized": "Gwiezdne Ostrza",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417298,
      "m_Localized": "Oddział wojowników o świecących mieczach wylądował, oświadczając, że twój klan nie jest godny rządzić tymi ziemiami. Przegoń ich, zanim na dobre zdecydują o twoim losie.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417299,
      "m_Localized": "Inwazja Obcych",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417300,
      "m_Localized": "Istoty z innej gwiazdy zaczęły zbierać twoich ludzi jak bydło. Walcz, zanim twój dom stanie się ich kolonią.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417301,
      "m_Localized": "Kolosalne Ostrze",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417302,
      "m_Localized": "Wojownik walczy ostrzem większym niż jakikolwiek dom. Jeśli twój klan go nie zatrzyma, nic innego tego nie zrobi.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417303,
      "m_Localized": "Cyfrowe Włamanie",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417304,
      "m_Localized": "Rozdarcie w cyfrowej rzeczywistości uwolniło dziwnych wojowników światła i liczb. Zamknij wyłom, zanim przepiszą twoje ziemie.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417305,
      "m_Localized": "Technologia to za mało",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417306,
      "m_Localized": "Zwykli wojownicy uzbroili się w świecące, technologiczne ostrza, wierząc, że czyni ich to niezwyciężonymi. Udowodnij, że prawdziwa siła wciąż się liczy.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417307,
      "m_Localized": "Kwantowi Rebelianci",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417308,
      "m_Localized": "Pojawiła się grupa krzykliwych wojowników uzbrojonych w niestabilną broń kwantową. Ich moc jest dzika i niebezpieczna, a twój klan musi ich powstrzymać, zanim szkody się rozprzestrzenią.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417309,
      "m_Localized": "Zakon Tronu",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417310,
      "m_Localized": "Władca wysłał elitarnych strażników, by podporządkować twój klan koronie. Pokaż, że twój klan nie odpowiada żadnemu tronowi.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417311,
      "m_Localized": "Dwaj Czarodzieje",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417312,
      "m_Localized": "Magowie twierdzą, że przyszli „przekształcić\" twoje terytorium. Twój klan musi odpowiedzieć stalą i odwagą i złamać ich zaklęcia.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417313,
      "m_Localized": "Zstąp z Góry",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417314,
      "m_Localized": "Zastęp aniołów zstąpił, twierdząc, że twój klan stał się zbyt dumny. Udowodnij swoją wartość albo zostań wymazany w imię czystości.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417315,
      "m_Localized": "Nocni Czarnoksiężnicy",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417316,
      "m_Localized": "Gdzie chodzą ci czarodzieje, plony zawodzą, a ludzie znikają. Wypędź ich, zanim twój dom stanie się kolejnym martwym miejscem.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417317,
      "m_Localized": "Z Podziemnego Świata",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417318,
      "m_Localized": "Wojownicy powstali z głębin, gdzie żywi nie należą. Jeśli twój klan ich nie zatrzyma, powierzchnia stanie się ich nowym królestwem.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 88072866833096704,
      "m_Localized": "Poziomy misji {0}-{1}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 90987145798344704,
      "m_Localized": "Jesteś już w innej misji!",
      "m_Metadata": {
        "m_Items": []
      }
    }
  ],
