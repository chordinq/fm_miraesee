      }
    },
    {
      "m_Id": 6882146555457536,
      "m_Localized": "กำลังต่อสู้...",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 25460050683224064,
      "m_Localized": "เวลาระดมพล",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695739834368,
      "m_Localized": "เสียงหอนแห่งยุคแรก",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417280,
      "m_Localized": "เผ่าที่ถูกลืมเลือนได้คลานออกมาจากป่าเถื่อน ปล้นกองคาราวานด้วยหินและกระดูก หากไม่ถูกขับไล่ พื้นที่ล่าสัตว์ของพวกเขาจะรวมถึงแคลนของคุณในไม่ช้า",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417281,
      "m_Localized": "ยุคหินที่สอง",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417282,
      "m_Localized": "สิ่งที่เคยเป็นเพียงกลุ่มเล็กๆ ได้กลายเป็นสิ่งเลวร้ายกว่า หากแคลนของคุณไม่ลงมือ พวกเขาจะปกครองดินแดนเหล่านี้ในไม่ช้า",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417283,
      "m_Localized": "ซามูไรฝาแฝด",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417284,
      "m_Localized": "นักดาบผู้เชี่ยวชาญสองคนเดินไปทั่วดินแดนของคุณ ฟันผู้ใดก็ตามที่กล้าท้าทาย จงกำจัดฝาแฝดก่อนที่ตำนานของพวกเขาจะทำให้แคลนของคุณจมอยู่ในความกลัว",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417285,
      "m_Localized": "กองทัพหมวก",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417286,
      "m_Localized": "นักรบเหล่านี้ซ่อนอยู่หลังเหล็กและอาวุธหนัก คิดว่าตัวเองไม่อาจถูกทำลายได้ จงแสดงให้พวกเขาเห็นว่าแม้แต่เหล็กก็โค้งงอต่อหน้าแคลนของคุณ",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417287,
      "m_Localized": "ใบเรือดำ",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417288,
      "m_Localized": "เรือไร้ธงได้ทอดสมอใกล้ดินแดนของคุณ พวกโจรสลัดวางแผนปล้นทุกอย่างที่ไม่ได้ตอกตะปูเอาไว้",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417289,
      "m_Localized": "สามทหารเสือ",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417290,
      "m_Localized": "ปรมาจารย์เหล่านี้ต้องการพิสูจน์ว่ามีเพียงพวกเขาเท่านั้นที่สมควรได้รับการเคารพและการปกครอง จงแสดงให้พวกเขาเห็นว่าแคลนของคุณไม่ก้มหัวให้ใบมีดใด",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417291,
      "m_Localized": "การโจมตีของอันธพาล",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417292,
      "m_Localized": "แก๊งอันธพาลมาเก็บ \"ภาษี\" จากรายได้ที่แคลนของคุณหามาอย่างยากลำบาก คุณปฏิเสธที่จะจ่าย — และตอนนี้พวกเขาอยู่ที่หน้าประตูแล้ว ยืนหยัดและแสดงให้พวกเขาเห็นว่าแคลนของคุณไม่ก้มหัวต่อการข่มขู่",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417293,
      "m_Localized": "กฎหมายมาเคาะประตู",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417294,
      "m_Localized": "คุณปฏิเสธความร่วมมือกับเผด็จการ เลือกอิสรภาพแทนโซ่ตรวน ตอนนี้หน่วยติดเกราะของเขากำลังเดินทัพมาเพื่อเชือดไก่ให้ลิงดู",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417295,
      "m_Localized": "หน่วยพิษนำหน้า",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 78356377112666112,
      "m_Localized": "หน่วยสวมหน้ากากที่ติดอาวุธเทคโนโลยีต้องห้ามได้เข้ามาในดินแดนของคุณ ทิ้งอากาศไหม้เกรียมไว้เบื้องหลัง หยุดยั้งการรุกของพวกเขาก่อนที่จะสร้างความเสียหายเพิ่ม",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417297,
      "m_Localized": "ดาบดารา",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417298,
      "m_Localized": "หน่วยนักรบดาบเรืองแสงได้ลงจอด ประกาศว่าแคลนของคุณไม่เหมาะที่จะปกครองดินแดนเหล่านี้ จงขับไล่พวกเขาก่อนที่จะตัดสินชะตากรรมของคุณตลอดไป",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417299,
      "m_Localized": "การรุกรานของมนุษย์ต่างดาว",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417300,
      "m_Localized": "สิ่งมีชีวิตจากดาวอีกดวงเริ่มเก็บเกี่ยวผู้คนของคุณราวกับฝูงปศุสัตว์ ตอบโต้ก่อนที่บ้านของคุณจะกลายเป็นอาณานิคมของพวกเขา",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417301,
      "m_Localized": "ดาบยักษ์",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417302,
      "m_Localized": "นักรบคนนี้ต่อสู้ด้วยใบมีดที่ใหญ่กว่าบ้านใดๆ หากแคลนของคุณหยุดเขาไม่ได้ ไม่มีสิ่งใดจะหยุดเขาได้",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417303,
      "m_Localized": "การบุกรุกดิจิทัล",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417304,
      "m_Localized": "รอยขาดในอาณาจักรข้อมูลได้ปล่อยนักรบประหลาดของแสงและตัวเลขออกมา ปิดรอยรั่วก่อนที่พวกเขาจะเขียนดินแดนของคุณใหม่",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417305,
      "m_Localized": "เทคโนโลยีไม่เพียงพอ",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417306,
      "m_Localized": "นักสู้ทั่วไปได้ติดอาวุธด้วยใบมีดเทคเรืองแสง เชื่อว่ามันทำให้พวกเขาไร้พ่าย จงพิสูจน์ว่าพลังที่แท้จริงยังคงมีความสำคัญ",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417307,
      "m_Localized": "กบฏควอนตัม",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417308,
      "m_Localized": "หมู่นักรบหรูหราได้ปรากฏตัวพร้อมกับอาวุธควอนตัมที่ไม่เสถียร พลังของพวกเขารุนแรงและอันตราย แคลนของคุณต้องหยุดยั้งก่อนที่ความเสียหายจะลุกลาม",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417309,
      "m_Localized": "ภาคีบัลลังก์",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417310,
      "m_Localized": "ผู้ปกครองส่งทหารองครักษ์ระดับสูงมาเพื่อนำแคลนของคุณไว้ใต้มงกุฎ จงแสดงให้เห็นว่าแคลนของคุณไม่ตอบรับบัลลังก์ใด",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417311,
      "m_Localized": "พ่อมดทั้งสอง",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417312,
      "m_Localized": "นักเวทกล่าวอ้างว่าพวกเขามาเพื่อ \"ปรับแต่ง\" ดินแดนของคุณตามใจ แคลนของคุณต้องตอบสนองเหล็กด้วยความกล้าและทำลายมนตราของพวกเขา",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417313,
      "m_Localized": "ลงมาจากเบื้องบน",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417314,
      "m_Localized": "ฝูงเทวดาได้ลงมา อ้างว่าแคลนของคุณภาคภูมิเกินไป จงพิสูจน์คุณค่าของคุณ ไม่เช่นนั้นจะถูกลบล้างในนามของความบริสุทธิ์",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417315,
      "m_Localized": "ผู้วิเศษราตรี",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417316,
      "m_Localized": "ที่ใดที่ผู้ใช้เวทย์เหล่านี้เดินผ่าน พืชผลล้มเหลวและผู้คนหายไป จงขับไล่พวกเขาก่อนที่บ้านของคุณจะกลายเป็นอีกสถานที่มรณะ",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417317,
      "m_Localized": "จากยมโลก",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417318,
      "m_Localized": "นักรบได้ลุกขึ้นจากห้วงลึกที่คนเป็นไม่ควรอยู่ หากแคลนของคุณหยุดพวกเขาไม่ได้ ผิวโลกจะกลายเป็นอาณาจักรใหม่ของพวกเขา",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 88072866833096704,
      "m_Localized": "ระดับภารกิจ {0}-{1}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 90987145798344704,
      "m_Localized": "คุณอยู่ในภารกิจอื่นแล้ว!",
      "m_Metadata": {
        "m_Items": []
      }
    }
  ],
