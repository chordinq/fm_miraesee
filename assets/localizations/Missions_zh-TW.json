      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695739834368,
      "m_Localized": "第一紀元的咆哮",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417280,
      "m_Localized": "一個被遺忘的部落從荒野中爬了出來，用石頭和骨頭襲擊商隊。若不將他們趕回去，他們的獵場很快就會包含你的氏族。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417281,
      "m_Localized": "第二石器時代",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417282,
      "m_Localized": "曾經只是一支簡單的部落，已演變成更糟的存在。若你的氏族不採取行動，他們很快將統治這片土地。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417283,
      "m_Localized": "雙生武士",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417284,
      "m_Localized": "兩位劍術大師走遍你的領地，砍倒任何挑戰他們的人。在他們的傳奇讓你的氏族陷入恐懼之前，擊敗這對雙胞胎。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417285,
      "m_Localized": "頭盔軍團",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417286,
      "m_Localized": "這些戰士躲在鐵甲和重型武器後面，自認為堅不可摧。讓他們看到，即使是鋼鐵也會在你氏族面前彎曲。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417287,
      "m_Localized": "黑帆",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417288,
      "m_Localized": "沒有旗幟的船隻已停泊在你的領地附近。海盜計劃搶走任何沒有釘住的東西。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417289,
      "m_Localized": "三劍客",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417290,
      "m_Localized": "這些大師試圖證明只有他們配得上尊敬和統治。讓他們看到你的氏族不向任何刀劍低頭。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417291,
      "m_Localized": "惡棍襲擊",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417292,
      "m_Localized": "一群惡棍前來向你氏族來之不易的收入徵收「稅」。你拒絕付錢——現在他們已經到了你的大門口。堅守陣地，讓他們看到你的氏族不會向威脅低頭。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417293,
      "m_Localized": "法律來敲門",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417294,
      "m_Localized": "你拒絕了獨裁者的合作，選擇了自由而非枷鎖。現在他的裝甲部隊正在進軍，要拿你的人民殺一儆百。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417295,
      "m_Localized": "毒性先鋒",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 78356377112666112,
      "m_Localized": "一支戴著面具、配備禁忌科技的部隊已進入你的領土，留下了灼燒的空氣。在他們造成更多破壞之前阻止他們前進。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417297,
      "m_Localized": "星之刃",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417298,
      "m_Localized": "一隊發光劍戰士已經降落，宣稱你的氏族不配統治這片土地。在他們永久決定你的命運之前將他們趕走。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417299,
      "m_Localized": "外星入侵",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417300,
      "m_Localized": "來自另一顆星辰的生物已開始像牛群一樣收割你的人民。在你的家成為他們的殖民地之前反擊。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417301,
      "m_Localized": "巨刃",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417302,
      "m_Localized": "這位戰士用一把比任何房屋都要大的劍戰鬥。若你的氏族無法阻止他，沒有任何東西能夠阻止。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417303,
      "m_Localized": "數位入侵",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417304,
      "m_Localized": "資料領域中的裂縫釋放出由光和數字組成的奇怪戰士。在他們改寫你的土地之前關閉這個裂縫。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417305,
      "m_Localized": "科技還不夠",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417306,
      "m_Localized": "普通戰士已用發光的科技刀刃武裝自己，相信這讓他們無懈可擊。證明真正的力量仍然重要。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417307,
      "m_Localized": "量子叛軍",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417308,
      "m_Localized": "一群華麗的戰士出現了，配備了不穩定的量子武器。他們的力量狂野而危險，你的氏族必須在傷害蔓延之前阻止他們。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417309,
      "m_Localized": "王座之序",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417310,
      "m_Localized": "統治者派遣他的精銳衛兵把你的氏族置於王冠之下。表明你的氏族不向任何王座效忠。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417311,
      "m_Localized": "雙巫",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417312,
      "m_Localized": "法師宣稱他們前來「重塑」你的領土。你的氏族必須以勇氣回應鋼鐵，並破除他們的咒語。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417313,
      "m_Localized": "自上方降臨",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417314,
      "m_Localized": "一群天使已降臨，宣稱你的氏族變得過於驕傲。證明你的價值，否則就會以純潔之名被抹滅。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417315,
      "m_Localized": "夜之術師",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417316,
      "m_Localized": "這些施法者所到之處，作物枯萎、人民失蹤。在你的家成為另一個死地之前將他們趕走。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417317,
      "m_Localized": "來自冥界",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417318,
      "m_Localized": "戰士已從活人不該存在的深處升起。若你的氏族未能阻止他們，地表將成為他們的新王國。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 88072866833096704,
      "m_Localized": "任務等級 {0}-{1}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 90987145798344704,
      "m_Localized": "你已在另一個任務中！",
      "m_Metadata": {
        "m_Items": []
      }
    }
  ],
