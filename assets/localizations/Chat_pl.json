        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009346,
      "m_Localized": "Nie spamuj ani nie zalewaj czatu.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009347,
      "m_Localized": "Nie podszywaj się pod innych graczy, moderatorów ani pracowników.",
