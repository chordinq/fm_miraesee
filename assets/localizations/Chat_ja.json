    {
      "m_Id": 14149557431558144,
      "m_Localized": "スパム/ジャンク",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290084843520,
      "m_Localized": "他のプレイヤーを嫌がらせ、侮辱、または脅迫しないでください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009344,
      "m_Localized": "ヘイトスピーチ、中傷、差別的な言葉を使わないでください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009345,
      "m_Localized": "薬物、宗教、政治、または性的な話題を話さないでください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009346,
      "m_Localized": "チャットをスパムしたり、フラッドしたりしないでください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009347,
      "m_Localized": "他のプレイヤー、モデレーター、またはスタッフになりすまさないでください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009348,
      "m_Localized": "プライベートまたは個人情報を共有しないでください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009349,
      "m_Localized": "報告システムを悪用しないでください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009350,
      "m_Localized": "詳細は、私たちの",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009351,
      "m_Localized": "チャットルール",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
