    {
      "m_Id": 14149557431558144,
      "m_Localized": "Спам/Мусор",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290084843520,
      "m_Localized": "Не преследуйте, не оскорбляйте и не угрожайте другим игрокам.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009344,
      "m_Localized": "Не используйте ненавистнические высказывания, оскорбления или дискриминационный язык.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009345,
      "m_Localized": "Не обсуждайте наркотики, религию, политику или сексуальные темы.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009346,
      "m_Localized": "Не спамьте и не засоряйте чат.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009347,
      "m_Localized": "Не выдавайте себя за других игроков, модераторов или сотрудников.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009348,
      "m_Localized": "Не делитесь личной или конфиденциальной информацией.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009349,
      "m_Localized": "Не злоупотребляйте системой жалоб.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009350,
      "m_Localized": "Дополнительную информацию вы найдете в нашем",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009351,
