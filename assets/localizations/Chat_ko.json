    },
    {
      "m_Id": 14149557431558144,
      "m_Localized": "스팸/정크",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290084843520,
      "m_Localized": "다른 플레이어를 괴롭히거나, 모욕하거나, 위협하지 마세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009344,
      "m_Localized": "혐오 발언, 비방 또는 차별적 언어를 사용하지 마세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009345,
      "m_Localized": "약물, 종교, 정치 또는 성적인 주제를 논의하지 마세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009346,
      "m_Localized": "채팅을 스팸하거나 도배하지 마세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009347,
      "m_Localized": "다른 플레이어, 관리자 또는 직원을 사칭하지 마세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009348,
      "m_Localized": "사적인 정보나 개인 정보를 공유하지 마세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009349,
      "m_Localized": "신고 시스템을 악용하지 마세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009350,
      "m_Localized": "자세한 정보는 우리의",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 33623290110009351,
      "m_Localized": "채팅 규칙",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 35993381137014784,
      "m_Localized": "당신은 음소거되었습니다",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
