  "m_TableData": [
    {
      "m_Id": 251863429120,
      "m_Localized": "ミッション",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 16036715491328,
      "m_Localized": "エネルギーは毎日{0}に補充されます。ミッションを成功させた場合にのみエネルギーが消費されます！",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 28244723822592,
      "m_Localized": "ラリー",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 44740485246976,
      "m_Localized": "成功！",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 45374441713664,
      "m_Localized": "失敗！",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 48422304018432,
      "m_Localized": "報酬を集める",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 52887002214400,
      "m_Localized": "ラリー",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623317729280,
      "m_Localized": "推奨パワー:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312192,
      "m_Localized": "総パワー:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312193,
      "m_Localized": "集結中... {0}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312194,
      "m_Localized": "{0} が <color=#{2}>レベル {1} ミッション</color> を完了しました",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6251320826327040,
      "m_Localized": "リフレッシュ",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6882146555457536,
      "m_Localized": "戦い",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 10232987525308416,
      "m_Localized": "サポート:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 14155878936276992,
      "m_Localized": "すべて集める",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 25460050683224064,
      "m_Localized": "集会の時間",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695739834368,
      "m_Localized": "最初の時代の遠吠え",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417280,
      "m_Localized": "忘れられた部族が野生から這い出し、石と骨でキャラバンを襲撃しています。追い返さなければ、彼らの狩猟場にあなたの一族も含まれるでしょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417281,
      "m_Localized": "第二の石器時代",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417282,
      "m_Localized": "かつては単なる集団だったものが、今ではもっと悪いものになっています。あなたの一族が行動しなければ、彼らはすぐにこの地を支配するでしょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417283,
      "m_Localized": "双子の侍",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417284,
      "m_Localized": "二人の剣の達人があなたの土地を歩き、挑む者を切り倒しています。彼らの伝説があなたの一族を恐怖に陥れる前に、双子を倒してください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417285,
      "m_Localized": "ヘルム軍団",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417286,
      "m_Localized": "これらの戦士たちは鉄と重武装の背後に隠れ、無敵だと思っています。あなたの一族の前では鋼鉄さえも屈することを示しましょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417287,
      "m_Localized": "黒い帆",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417288,
      "m_Localized": "旗のない船があなたの土地の近くに停泊しています。海賊たちは固定されていないものをすべて略奪するつもりです。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417289,
      "m_Localized": "三銃士",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417290,
      "m_Localized": "これらの達人たちは、自分たちだけが尊敬と支配に値すると証明しようとしています。あなたの一族がどんな剣にも屈しないことを示しましょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417291,
      "m_Localized": "暴漢の襲撃",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417292,
      "m_Localized": "暴漢の一団が、あなたの一族の苦労して得た収入に「税金」を課しに来ました。あなたは支払いを拒否しました - そして今、彼らは門前にいます。立ち上がり、あなたの一族が脅しに屈しないことを示しましょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417293,
      "m_Localized": "法律がやってくる",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417294,
      "m_Localized": "独裁者とのパートナーシップを断り、鎖よりも自由を選びました。今、彼の装甲部隊があなたの人々に見せしめをしようと進軍しています。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417295,
      "m_Localized": "毒の先鋒",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417297,
      "m_Localized": "星の刃",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417298,
      "m_Localized": "光る剣を持つ戦士たちの部隊が上陸し、あなたの一族がこの地を治めるのに不適切だと宣言しました。彼らがあなたの運命を決める前に追い払いましょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417299,
      "m_Localized": "エイリアン侵略",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417300,
      "m_Localized": "別の星から来た存在があなたの人々を家畜のように収穫し始めました。あなたの家が彼らの植民地になる前に反撃しましょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417301,
      "m_Localized": "巨大な刃",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417302,
      "m_Localized": "その戦士は家よりも大きな刃で戦います。あなたの一族が彼を止められなければ、他に誰もできません。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417303,
      "m_Localized": "デジタル侵入",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417304,
      "m_Localized": "データ領域の裂け目から光と数字の奇妙な戦士たちが解き放たれました。彼らがあなたの土地を書き換える前に裂け目を閉じましょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417305,
      "m_Localized": "技術だけじゃ足りない",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417306,
      "m_Localized": "普通の戦士たちは光る技術のブレードで武装し、それが無敵にすると信じている。本当の強さがまだ重要であることを証明しよう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417307,
      "m_Localized": "量子反乱者",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417308,
      "m_Localized": "派手な戦士たちの一団が現れ、不安定な量子兵器で武装している。彼らの力は野性的で危険だ。被害が広がる前に、あなたのクランが彼らを止めなければならない。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417309,
      "m_Localized": "王座の命令",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417310,
      "m_Localized": "支配者は精鋭の護衛を送り、あなたの一族を王冠の下に置こうとしています。あなたの一族がどんな王座にも従わないことを示しましょう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417311,
      "m_Localized": "二人の魔法使い",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417312,
      "m_Localized": "魔法使いたちは、彼らの好みに合わせてあなたの領地を「再形成」しに来たと主張しています。あなたの一族は勇気を持って鋼で応え、彼らの魔法を打ち破らなければなりません。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417313,
      "m_Localized": "上から降りる",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417314,
      "m_Localized": "天使の群れが降りてきて、あなたの一族があまりにも誇り高くなったと主張しています。あなたの価値を証明するか、純粋さの名の下に消されるかです。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417315,
      "m_Localized": "夜の魔術師",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417316,
      "m_Localized": "彼らが歩くところでは作物が枯れ、人々が消える。あなたの家がまた一つの死の場所になる前に追い払え。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417317,
      "m_Localized": "冥界から",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417318,
      "m_Localized": "生者が属さない深淵から戦士たちが現れた。クランが彼らを止められなければ、地上は彼らの新しい王国になるだろう。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 78356377112666112,
      "m_Localized": "禁断の技術を持った仮面の部隊があなたの領土に侵入し、焦げた空気を残しています。彼らがさらに被害を与える前に進行を止めてください。",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 88072866833096704,
      "m_Localized": "ミッションレベル {0}-{1}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312195,
      "m_Localized": "{0} ミッション！",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 90987145798344704,
      "m_Localized": "他のミッションに参加中だよ！",
      "m_Metadata": {
        "m_Items": []
      }
    }
  ],
  "references": {
    "version": 2,
    "RefIds": []
  }
}