      }
    },
    {
      "m_Id": 52887002214400,
      "m_Localized": "랠리",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623317729280,
      "m_Localized": "권장 파워:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312192,
      "m_Localized": "총 파워:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312193,
      "m_Localized": "집결 중... {0}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312194,
      "m_Localized": "{0}이(가) <color=#{2}>레벨 {1} 임무</color>를 완료했습니다",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6251320826327040,
      "m_Localized": "새로고침",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 6882146555457536,
      "m_Localized": "전투",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 10232987525308416,
      "m_Localized": "지원:",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 14155878936276992,
      "m_Localized": "모두 수집",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 25460050683224064,
      "m_Localized": "집합 시간",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695739834368,
      "m_Localized": "첫 시대의 울부짖음",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417280,
      "m_Localized": "잊혀진 부족이 야생에서 기어나와 돌과 뼈로 캐러밴을 습격하고 있습니다. 그들을 물리치지 않으면, 곧 당신의 부족도 그들의 사냥터에 포함될 것입니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417281,
      "m_Localized": "두 번째 석기 시대",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417282,
      "m_Localized": "한때 단순한 무리였던 것이 이제는 더 나쁜 것으로 변했습니다. 당신의 부족이 행동하지 않으면, 그들은 곧 이 땅을 지배할 것입니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417283,
      "m_Localized": "쌍둥이 사무라이",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417284,
      "m_Localized": "두 명의 검술 대가가 당신의 땅을 거닐며 도전하는 자들을 베어내고 있습니다. 그들의 전설이 당신의 부족을 두려움에 빠뜨리기 전에 쌍둥이를 물리치세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417285,
      "m_Localized": "헬름 군단",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417286,
      "m_Localized": "이 전사들은 철과 무거운 무기 뒤에 숨으며 자신들이 무적이라고 믿습니다. 당신의 부족 앞에서 강철조차 굴복한다는 것을 보여주세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417287,
      "m_Localized": "검은 돛단배",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417288,
      "m_Localized": "깃발 없는 배들이 당신의 땅 근처에 정박했습니다. 해적들은 고정되지 않은 모든 것을 약탈할 계획입니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417289,
      "m_Localized": "삼총사",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417290,
      "m_Localized": "이 대가들은 오직 그들만이 존경과 지배를 받을 자격이 있다고 증명하려 합니다. 당신의 부족이 어떤 칼날에도 굴복하지 않는다는 것을 보여주세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417291,
      "m_Localized": "폭력배 공격",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417292,
      "m_Localized": "폭력배 무리가 당신의 부족이 힘들게 번 소득에 '세금'을 부과하러 왔습니다. 당신은 지불을 거부했고, 이제 그들이 당신의 문 앞에 있습니다. 당신의 부족이 위협에 굴복하지 않는다는 것을 보여주세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417293,
      "m_Localized": "법이 찾아온다",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417294,
      "m_Localized": "당신은 독재자의 동맹을 거절하고 자유를 선택했습니다. 이제 그의 장갑 부대가 당신의 사람들에게 본보기를 보이기 위해 행진하고 있습니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417295,
      "m_Localized": "독성 선봉대",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417297,
      "m_Localized": "별의 검",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417298,
      "m_Localized": "빛나는 검을 든 전사들이 착륙하여 당신의 부족이 이 땅을 다스리기에 부적합하다고 선언했습니다. 그들이 당신의 운명을 결정하기 전에 그들을 몰아내세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417299,
      "m_Localized": "외계 침공",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417300,
      "m_Localized": "다른 별에서 온 존재들이 당신의 사람들을 가축처럼 수확하기 시작했습니다. 집이 그들의 식민지가 되기 전에 반격하세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417301,
      "m_Localized": "거대한 칼날",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417302,
      "m_Localized": "전사는 집보다 큰 칼날로 싸웁니다. 당신의 부족이 그를 막지 못하면, 아무도 막을 수 없습니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417303,
      "m_Localized": "디지털 침입",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417304,
      "m_Localized": "데이터 영역의 틈이 빛과 숫자의 이상한 전사들을 풀어놓았습니다. 그들이 당신의 땅을 다시 쓰기 전에 틈을 닫으세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417305,
      "m_Localized": "기술만으론 부족해",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417306,
      "m_Localized": "일반 전사들이 빛나는 기술 블레이드로 무장하고 자신들이 무적이라고 믿고 있습니다. 진정한 힘이 여전히 중요하다는 것을 증명하세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417307,
      "m_Localized": "양자 반란자들",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417308,
      "m_Localized": "화려한 전사들이 불안정한 양자 무기로 무장하여 나타났습니다. 그들의 힘은 거칠고 위험하며, 피해가 확산되기 전에 당신의 클랜이 그들을 막아야 합니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417309,
      "m_Localized": "왕좌의 명령",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417310,
      "m_Localized": "통치자는 당신의 부족을 왕관 아래로 데려가기 위해 정예 경비병을 보냈습니다. 당신의 부족이 어떤 왕좌에도 굴복하지 않음을 보여주세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417311,
      "m_Localized": "두 마법사",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417312,
      "m_Localized": "마법사들은 그들의 취향에 맞게 당신의 영토를 '재구성'하러 왔다고 주장합니다. 당신의 부족은 용기로 강철에 맞서고 그들의 마법을 깨뜨려야 합니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417313,
      "m_Localized": "위에서 내려오다",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417314,
      "m_Localized": "천사들이 내려와 당신의 부족이 너무 자만했다고 주장합니다. 당신의 가치를 증명하거나 순수함의 이름으로 지워질 것입니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417315,
      "m_Localized": "밤의 마법사들",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417316,
      "m_Localized": "이 마법사들이 지나가는 곳마다 작물이 시들고 사람들이 사라집니다. 당신의 집이 또 다른 죽음의 장소가 되기 전에 그들을 몰아내세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417317,
      "m_Localized": "저승에서 온",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417318,
      "m_Localized": "살아있는 자들이 속하지 않는 깊은 곳에서 전사들이 일어났습니다. 당신의 부족이 그들을 막지 못하면, 지상은 그들의 새로운 왕국이 될 것입니다.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 78356377112666112,
      "m_Localized": "금지된 기술을 장착한 가면 부대가 당신의 영토에 들어와 타오르는 공기를 남기고 있습니다. 더 많은 피해를 주기 전에 그들의 진격을 막으세요.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 88072866833096704,
      "m_Localized": "임무 레벨 {0}-{1}",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 1090623330312195,
      "m_Localized": "{0} 임무!",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 90987145798344704,
      "m_Localized": "이미 다른 임무 중이야!",
      "m_Metadata": {
        "m_Items": []
      }
    }
  ],
