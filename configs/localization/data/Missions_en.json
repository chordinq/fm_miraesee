    {
      "m_Id": 70472695739834368,
      "m_Localized": "Howl of the First Age",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417280,
      "m_Localized": "A forgotten tribe has crawled out of the wilds, raiding caravans with stone and bone. If they aren’t driven back, their hunting grounds will soon include your clan.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417281,
      "m_Localized": "The Second Stone Age",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417282,
      "m_Localized": "What was once a simple band has become something worse. If your clan does not act, they will soon rule these lands.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417283,
      "m_Localized": "The Twin Samurai",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417284,
      "m_Localized": "Two master swordsmen walk your lands, cutting down any who challenge them. Defeat the twins before their legend drowns your clan in fear.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417285,
      "m_Localized": "The Helm Legion",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417286,
      "m_Localized": "These fighters hide behind iron and heavy weapons, believing themselves untouchable. Show them that even steel bends before your clan.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417287,
      "m_Localized": "The Black Sails",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417288,
      "m_Localized": "Ships without flags have anchored near your lands. The pirates plan to loot everything that isn’t nailed down.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417289,
      "m_Localized": "The Three Musketeers",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417290,
      "m_Localized": "These masters seek to prove that only they deserve respect and rule. Show them your clan bows to no blade.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417291,
      "m_Localized": "Thug attack",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417292,
      "m_Localized": "A gang of thugs has come to collect a “tax” on your clan’s hard-earned income. You’ve refused to pay – and now they’re at your gates. Stand your ground and show them your clan doesn't bow to threats.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417293,
      "m_Localized": "The Law comes knocking",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417294,
      "m_Localized": "You turned down the dictator’s partnership, choosing freedom over chains. Now his armored units march in to make an example of your people.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417295,
      "m_Localized": "Toxic Vanguard",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417297,
      "m_Localized": "The Star Blades",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417298,
      "m_Localized": "A squad of glowing-sword warriors has landed, declaring your clan unfit to rule these lands. Drive them out before they decide your fate for good.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417299,
      "m_Localized": "Alien Invasion",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417300,
      "m_Localized": "Beings from another star have begun to harvest your people like cattle. Fight back before your home becomes their colony.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417301,
      "m_Localized": "The Colossal Blade",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417302,
      "m_Localized": "The warrior fights with a blade bigger than any house. If your clan cannot stop him, nothing else will.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417303,
      "m_Localized": "Digital Breach",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417304,
      "m_Localized": "A tear in the data realm has unleashed strange warriors of light and numbers. Close the breach before they rewrite your lands.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417305,
      "m_Localized": "Tech is not enough",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417306,
      "m_Localized": "Ordinary fighters have armed themselves with glowing tech blades, believing it makes them invincible. Prove that real strength still matters.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417307,
      "m_Localized": "Quantum Rebels",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417308,
      "m_Localized": "A crew of flashy warriors has appeared, armed with unstable quantum weapons. Their power is wild and dangerous, and your clan must stop them before the damage spreads.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417309,
      "m_Localized": "Order of the Throne",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417310,
      "m_Localized": "The ruler has sent his elite guards to bring your clan under the crown. Show that your clan answers to no throne.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417311,
      "m_Localized": "The Two Wizards",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417312,
      "m_Localized": "The mages claim they come to “reshape” your territory to their liking. Your clan must answer steel with courage and break their enchantments.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417313,
      "m_Localized": "Descend from above",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417314,
      "m_Localized": "A host of angels has descended, claiming your clan has grown too proud. Prove your worth, or be erased in the name of purity.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417315,
      "m_Localized": "Night Sorcerers",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417316,
      "m_Localized": "Wherever these spellcasters walk, crops fail and people vanish. Drive them out before your home becomes another dead place.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417317,
      "m_Localized": "From the Underworld",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 70472695752417318,
      "m_Localized": "Warriors have risen from the depths where the living do not belong. If your clan fails to stop them, the surface will become their new kingdom.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 78356377112666112,
      "m_Localized": "A masked unit armed with forbidden tech has entered your territory, leaving scorched air behind them. Stop their advance before they cause more damage.",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 88072866833096704,
      "m_Localized": "Mission Levels {0}-{1}",
      "m_Metadata": {
