      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 12024958489190405,
      "m_Localized": "더 멀리 갈수록 보상이 늘어납니다!",
      "m_Metadata": {
        "m_Items": []
      }
    },
    {
      "m_Id": 12024958489190406,
